{
  "name": "launchpromptly",
  "version": "0.1.0",
  "description": "LaunchPromptly Node.js SDK — manage, version, and deploy AI prompts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/launchpromptly/node-sdk"
  },
  "keywords": [
    "launchpromptly",
    "prompt-management",
    "llm",
    "ai",
    "openai",
    "anthropic",
    "prompt-versioning",
    "sdk"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "jest --passWithNoTests",
    "test:integration": "tsx tests/integration-test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.7.0"
  }
}
