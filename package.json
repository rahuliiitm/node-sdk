{
  "name": "launchpromptly",
  "version": "0.3.1",
  "description": "LaunchPromptly Node.js SDK — runtime safety layer for LLM applications (PII redaction, injection detection, cost guards)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rahuliiitm/node-sdk"
  },
  "keywords": [
    "launchpromptly",
    "llm-security",
    "pii-redaction",
    "prompt-injection",
    "cost-guard",
    "llm",
    "ai",
    "openai",
    "anthropic",
    "gemini",
    "content-filter",
    "guardrails",
    "sdk"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./ml": {
      "types": "./dist/ml/index.d.ts",
      "require": "./dist/ml/index.js",
      "import": "./dist/ml/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "jest --passWithNoTests",
    "test:integration": "tsx tests/integration-test.ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "onnxruntime-node": ">=1.16.0",
    "@huggingface/transformers": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "onnxruntime-node": {
      "optional": true
    },
    "@huggingface/transformers": {
      "optional": true
    }
  },
  "devDependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.7.0"
  }
}
